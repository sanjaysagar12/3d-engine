{
  "garment": "aaron",
  "version": "1.3-alignment-added",
  "description": "Stitching instructions for front, back, and mirrored panels",
  "alignment": {
    "front": "AP_FRONT_RIGHT",
    "front_mirror": "AP_FRONT_LEFT",
    "back": "AP_BACK_RIGHT",
    "back_mirror": "AP_BACK_LEFT"
  },
  "seams": [
    {
      "seam_id": "S1",
      "label": "Front to Front Mirror",
      "description": "Stitch front panel to front mirror panel",
      "from": {
        "piece_a": "front",
        "point_a": "pt-0",
        "piece_b": "front_mirror",
        "point_b": "pt-0"
      },
      "to": {
        "piece_a": "front",
        "point_a": "pt-1",
        "piece_b": "front_mirror",
        "point_b": "pt-11"
      }
    },
    {
      "seam_id": "S2",
      "label": "Back to Back Mirror",
      "description": "Stitch back panel to back mirror panel",
      "from": {
        "piece_a": "back",
        "point_a": "pt-12",
        "piece_b": "back_mirror",
        "point_b": "pt-1"
      },
      "to": {
        "piece_a": "back",
        "point_a": "pt-1",
        "piece_b": "back_mirror",
        "point_b": "pt-12"
      }
    },
    {
      "seam_id": "S3",
      "label": "Shoulder: Back Mirror to Front Mirror",
      "description": "Stitch back mirror shoulder to front mirror shoulder",
      "from": {
        "piece_a": "back_mirror",
        "point_a": "pt-9",
        "piece_b": "front_mirror",
        "point_b": "pt-8"
      },
      "to": {
        "piece_a": "back_mirror",
        "point_a": "pt-11",
        "piece_b": "front_mirror",
        "point_b": "pt-10"
      }
    },
    {
      "seam_id": "S4",
      "label": "Shoulder: Back to Front",
      "description": "Stitch back shoulder to front shoulder",
      "from": {
        "piece_a": "back",
        "point_a": "pt-10",
        "piece_b": "front",
        "point_b": "pt-9"
      },
      "to": {
        "piece_a": "back",
        "point_a": "pt-8",
        "piece_b": "front",
        "point_b": "pt-8"
      }
    },
    {
      "seam_id": "S5",
      "label": "Side: Back to Front",
      "description": "Stitch back side seam to front side seam",
      "from": {
        "piece_a": "back",
        "point_a": "pt-5",
        "piece_b": "front",
        "point_b": "pt-4"
      },
      "to": {
        "piece_a": "back",
        "point_a": "pt-2",
        "piece_b": "front",
        "point_b": "pt-2"
      }
    },
    {
      "seam_id": "S6",
      "label": "Side: Back Mirror to Front Mirror",
      "description": "Stitch back mirror side seam to front mirror side seam",
      "from": {
        "piece_a": "back_mirror",
        "point_a": "pt-5",
        "piece_b": "front_mirror",
        "point_b": "pt-4"
      },
      "to": {
        "piece_a": "back_mirror",
        "point_a": "pt-4",
        "piece_b": "front_mirror",
        "point_b": "pt-3"
      }
    }
  ]
}